{
  "name": "x-spam-sentinel-edge",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker — public API + D1 curation store for x-spam-sentinel.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute xss-db --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute xss-db --remote --file=./schema.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.92.0"
  }
}
